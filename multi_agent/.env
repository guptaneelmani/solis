# Groq — free tier at groq.com
GROQ_API_KEY=your_groq_api_key_here

# Tavily — free tier at tavily.com (1,000 searches/month)
TAVILY_API_KEY=your_tavily_api_key_here

# Telegram — token from @BotFather, your user ID from @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_IDS=your_telegram_user_id_here
